# Server Configuration
PORT=8787
USE_WS=true
NODE_ENV=development

# JWT Secret
JWT_SECRET=change_this_to_a_secure_random_secret

# MySQL Configuration (Docker)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=jure
MYSQL_PASSWORD=jur3pass
MYSQL_DATABASE=jure_ai

# Prisma
DATABASE_URL="mysql://root:jur3pass@mysql:3306/jure_ai"

# Groq API (optional)
GROQ_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Speech
STT_LANGUAGE=fr
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=company_knowledge_fr
